function RestTimer() {
  const [visible, setVisible]   = useState(false);
  const [duration, setDuration] = useState(60);
  const [timeLeft, setTimeLeft] = useState(60);
  const [running, setRunning]   = useState(false);
  const [finished, setFinished] = useState(false);
  const intervalRef = useRef(null);

  // Durées rapides prédéfinies (secondes)
  const presets = [30, 45, 60, 90, 120];

  useEffect(() => {
    if (running && timeLeft > 0) {
      intervalRef.current = setInterval(() => setTimeLeft(t => t - 1), 1000);
    } else if (timeLeft === 0 && running) {
      setRunning(false);
      setFinished(true);
      clearInterval(intervalRef.current);
    }
    return () => clearInterval(intervalRef.current);
  }, [running, timeLeft]);

  const start = (sec) => {
    const d = sec || duration;
    setDuration(d);
    setTimeLeft(d);
    setRunning(true);
    setFinished(false);
  };

  const reset = () => {
    clearInterval(intervalRef.current);
    setRunning(false);
    setFinished(false);
    setTimeLeft(duration);
  };

  const toggle = () => {
    if (running) { clearInterval(intervalRef.current); setRunning(false); }
    else if (timeLeft > 0) { setRunning(true); setFinished(false); }
  };

  const fmt = (s) => {
    const m = Math.floor(s / 60);
    const ss = s % 60;
    return (m < 10 ? "0" : "") + m + ":" + (ss < 10 ? "0" : "") + ss;
  };

  const progress = ((duration - timeLeft) / duration) * 100;
  const accentColor = finished ? "#7BB490" : running ? "#C47A8A" : "#C9A84C";

  return (
    <>
      {/* Bouton flottant */}
      <button
        onClick={() => setVisible(v => !v)}
        style={{
          position:"fixed", bottom:24, right:20, zIndex:300,
          width:50, height:50, borderRadius:25,
          background: running ? "#C47A8A" : finished ? "#7BB490" : "#1c1a19",
          border: "1px solid " + (running ? "#C47A8A44" : "#2a2725"),
          color: running || finished ? "#fff" : "#888",
          fontSize:18, cursor:"pointer",
          boxShadow:"0 4px 20px rgba(0,0,0,0.4)",
          display:"flex", alignItems:"center", justifyContent:"center",
          transition:"all 0.2s",
          animation: running ? "timerPulse 2s ease infinite" : "none"
        }}
        title="Timer de repos"
      >
        {finished ? "✓" : "⏱"}
      </button>

      {/* Panel flottant */}
      {visible && (
        <div
          className="fade-in"
          style={{
            position:"fixed", bottom:84, right:16, zIndex:300,
            background:"#1c1a19", border:"1px solid #2a2725",
            borderRadius:14, padding:"16px 16px 14px",
            width:220, boxShadow:"0 12px 40px rgba(0,0,0,0.5)"
          }}
        >
          {/* Header */}
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
            <span style={{ fontSize:11, fontWeight:700, color:"#ccc", letterSpacing:0.5, textTransform:"uppercase" }}>Repos</span>
            <button onClick={() => setVisible(false)} style={{ background:"none", border:"none", color:"#555", fontSize:16, cursor:"pointer" }}>×</button>
          </div>

          {/* Cercle de progression */}
          <div style={{ display:"flex", flexDirection:"column", alignItems:"center", marginBottom:12 }}>
            <div style={{ position:"relative", width:90, height:90 }}>
              <svg width="90" height="90" style={{ transform:"rotate(-90deg)" }}>
                <circle cx="45" cy="45" r="38" fill="none" stroke="#2a2725" strokeWidth="5" />
                <circle cx="45" cy="45" r="38" fill="none" stroke={accentColor} strokeWidth="5"
                  strokeDasharray={2 * Math.PI * 38}
                  strokeDashoffset={2 * Math.PI * 38 * (1 - progress / 100)}
                  style={{ transition:"stroke-dashoffset 0.5s, stroke 0.3s" }}
                />
              </svg>
              <div style={{ position:"absolute", inset:0, display:"flex", alignItems:"center", justifyContent:"center", flexDirection:"column" }}>
                <span style={{ fontSize:20, fontWeight:800, color: accentColor, fontVariantNumeric:"tabular-nums", lineHeight:1 }}>
                  {fmt(timeLeft)}
                </span>
                {finished && <span style={{ fontSize:9, color:"#7BB490", fontWeight:600, marginTop:2 }}>Terminé!</span>}
              </div>
            </div>
          </div>

          {/* Boutons rapides */}
          <div style={{ display:"flex", gap:4, marginBottom:10, justifyContent:"center" }}>
            {presets.map(p => (
              <button key={p} onClick={() => start(p)}
                style={{
                  padding:"4px 6px", borderRadius:6, border:"1px solid #2a2725",
                  background: duration === p && !running ? "#2a2725" : "transparent",
                  color: duration === p && !running ? "#e8e4e1" : "#666",
                  fontSize:10, fontWeight:600, cursor:"pointer"
                }}
              >
                {p < 60 ? p+"s" : (p/60)+"m"}
              </button>
            ))}
          </div>

          {/* Contrôles */}
          <div style={{ display:"flex", gap:6 }}>
            <button onClick={toggle}
              style={{
                flex:2, padding:"9px", borderRadius:8, border:"none",
                background: running ? "#333" : accentColor,
                color: running ? "#aaa" : "#fff",
                fontSize:12, fontWeight:700, cursor:"pointer"
              }}
            >
              {running ? "Pause" : finished ? "Repart" : timeLeft < duration ? "Reprendre" : "Démarrer"}
            </button>
            <button onClick={reset}
              style={{
                flex:1, padding:"9px", borderRadius:8, border:"1px solid #2a2725",
                background:"transparent", color:"#666", fontSize:12, cursor:"pointer"
              }}
            >
              Reset
            </button>
          </div>
        </div>
      )}
    </>
  );
}

