{"routine":"Leg Day Glute","type":"Hypertrophie","duration":"60 min","blocks":["Back Squat 4×10","RDL 4×8","Hip Thrust 3×12","StairMaster 10 min"],"notes":"Séance jambes focus postérieur"}
:::END_JOURNAL:::

Types valides: Hyrox, Hybride, Hypertrophie, Calisthenics, Renfo Course, Duo, Strongman, Cardio, Récupération.
Ne mentionne PAS le bloc JSON dans ta réponse textuelle — il sera traité silencieusement par l'app.`;

function buildSystemPrompt(exercises) {
  const exList = exercises.map(e => `${e.name} (${e.category}, ${e.type}, ${e.equipment}, freq:${e.frequency})`).join("\n");
  const base = LS.get("at_coach_prompt", DEFAULT_COACH_PROMPT);
  return base + "\n\nBANQUE D'EXERCICES (" + exercises.length + " exercices):\n" + exList;
}

async function callClaude(messages, apiKey, exercises) {
  const systemPrompt = buildSystemPrompt(exercises);
  const apiMessages = messages.map(m => ({ role: m.role === "user" ? "user" : "assistant", content: m.text }));
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": apiKey,
      "anthropic-version": "2023-06-01",
      "anthropic-dangerous-direct-browser-access": "true"
    },
    body: JSON.stringify({ model: "claude-haiku-4-5-20251001", max_tokens: 2000, system: systemPrompt, messages: apiMessages })
  });
  if (!res.ok) {
    if (res.status === 401) throw new Error("Clé API invalide. Vérifie ta clé dans les réglages.");
    if (res.status === 429) throw new Error("Trop de requêtes. Attends quelques secondes.");
    throw new Error("Erreur API: " + res.status);
  }
  const data = await res.json();
  return data.content[0].text;
}

