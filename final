        <div style={{ display:"flex", gap:8, marginTop:6 }}>
          <button onClick={onClose} style={{ flex:1, padding:"10px", borderRadius:8, border:"1px solid #333", background:"transparent", color:"#888", fontWeight:500, fontSize:13, cursor:"pointer" }}>Annuler</button>
          <button onClick={() => { if (f.name.trim()) { onSave(f); onClose(); } }}
            style={{ flex:1, padding:"10px", borderRadius:8, border:"none", background:f.name.trim() ? "#e8e4e1" : "#333", color:f.name.trim() ? "#131211" : "#555", fontWeight:700, fontSize:13, cursor:f.name.trim() ? "pointer" : "default" }}
          >Ajouter</button>
        </div>
      </div>
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 12 — MODE SÉANCE (CHRONO)
// ══════════════════════════════════════════════════════════════
function SessionMode({ routine, onEnd }) {
  const [step, setStep]       = useState(0);
  const [sec, setSec]         = useState(0);
  const [running, setRunning] = useState(true);
  const interval = useRef(null);

  useEffect(() => {
    if (running) interval.current = setInterval(() => setSec(s => s + 1), 1000);
    else clearInterval(interval.current);
    return () => clearInterval(interval.current);
  }, [running]);

  const fmt = (s) => { const m = Math.floor(s/60); const ss = s%60; return (m<10?"0":"")+m+":"+(ss<10?"0":"")+ss; };
  const c = rtColors[routine.type] || "#C47A8A";
  const total = routine.blocks.length;
  const done = step >= total;

  return (
    <div className="session-overlay fade-in">
      {/* Top bar */}
      <div style={{ background:"#1c1a19", borderBottom:"1px solid #2a2725", padding:"16px 20px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
        <button onClick={onEnd} style={{ background:"none", border:"none", color:"#888", fontSize:13, cursor:"pointer", fontWeight:500 }}>← Terminer</button>
        <div style={{ fontSize:28, fontWeight:800, color:c, fontVariantNumeric:"tabular-nums", animation:running?"timerPulse 2s ease infinite":"none" }}>{fmt(sec)}</div>
        <button onClick={() => setRunning(!running)}
          style={{ background:running?"#333":c, color:running?"#888":"#fff", border:"none", borderRadius:8, padding:"8px 14px", fontSize:12, fontWeight:600, cursor:"pointer" }}
        >{running ? "Pause" : "Reprendre"}</button>
      </div>

      {/* Titre */}
      <div style={{ padding:"20px 20px 8px", textAlign:"center" }}>
        <div style={{ fontSize:16, fontWeight:700, color:"#e8e4e1" }}>{routine.name}</div>
        <div style={{ fontSize:12, color:"#666", marginTop:4 }}>{done ? "Séance terminée!" : "Bloc "+(step+1)+" / "+total}</div>
      </div>

      {/* Barre de progression */}
      <div style={{ padding:"0 20px", marginBottom:16 }}>
        <div style={{ height:3, background:"#2a2725", borderRadius:2, overflow:"hidden" }}>
          <div style={{ width:((done?total:step)/total*100)+"%", height:"100%", background:c, borderRadius:2, transition:"width 0.4s" }} />
        </div>
      </div>

      {/* Blocs */}
      <div style={{ flex:1, padding:"0 20px 20px", overflowY:"auto" }}>
        {routine.blocks.map((b, i) => {
          const active = i === step, past = i < step;
          return (
            <div key={i} style={{
              background: active ? c+"15" : past ? "#1a1918" : "#1c1a19",
              border: active ? "1px solid "+c+"44" : "1px solid #2a2725",
              borderRadius:10, padding:active?"20px":"12px 16px", marginBottom:8, transition:"all 0.2s", opacity:past?0.5:1
            }}>
              <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center" }}>
                <div style={{ display:"flex", gap:10, alignItems:"center" }}>
                  <span style={{
                    width:24, height:24, borderRadius:6,
                    background: past?"#7BB490":active?c:"#333",
                    color: past||active?"#fff":"#555",
                    display:"flex", alignItems:"center", justifyContent:"center", fontSize:11, fontWeight:700, flexShrink:0
                  }}>{past ? "✓" : i+1}</span>
                  <span style={{ fontSize:active?14:12, fontWeight:active?600:400, color:active?"#e8e4e1":past?"#666":"#aaa" }}>{b}</span>
                </div>
              </div>
              {active && !done && (
                <button onClick={e => { e.stopPropagation(); setStep(step+1); }}
                  style={{ marginTop:14, width:"100%", padding:"12px", borderRadius:8, border:"none", background:c, color:"#fff", fontWeight:700, fontSize:14, cursor:"pointer", letterSpacing:0.3 }}
                >{step < total-1 ? "Bloc suivant →" : "Terminer ✓"}</button>
              )}
            </div>
          );
        })}
        {done && (
          <div style={{ textAlign:"center", padding:"24px 0" }}>
            <div style={{ fontSize:36, marginBottom:8 }}>🏆</div>
            <div style={{ fontSize:18, fontWeight:700, color:"#e8e4e1", marginBottom:4 }}>Séance complétée!</div>
            <div style={{ fontSize:14, color:"#888", marginBottom:16 }}>Durée: {fmt(sec)}</div>
            <button onClick={onEnd} style={{ padding:"12px 32px", borderRadius:8, border:"none", background:"#e8e4e1", color:"#131211", fontWeight:700, fontSize:14, cursor:"pointer" }}>
              Sauvegarder et fermer
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 13 — COACH IA
// ══════════════════════════════════════════════════════════════
function CoachTab({ pool }) {
  const [apiKey, setApiKey]         = useState(() => localStorage.getItem("at_api_key") || "");
  const [keyInput, setKeyInput]     = useState("");
  const [convos, setConvos]         = useState(() => LS.get("at_coach_convos", []));
  const [activeId, setActiveId]     = useState(() => { const c = LS.get("at_coach_convos", []); return c.length ? c[0].id : null; });
  const [input, setInput]           = useState("");
  const [loading, setLoading]       = useState(false);
  const [error, setError]           = useState("");
  const [showSettings, setShowSettings] = useState(false);
  const [showHistory, setShowHistory]   = useState(false);
  const [promptText, setPromptText] = useState(() => LS.get("at_coach_prompt", DEFAULT_COACH_PROMPT));
  const ref = useRef(null);
  const dropRef = useRef(null);

  useEffect(() => {
    if (!showHistory) return;
    const handler = (e) => { if (dropRef.current && !dropRef.current.contains(e.target)) setShowHistory(false); };
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, [showHistory]);

  const activeConvo = convos.find(c => c.id === activeId);
  const msgs = activeConvo ? activeConvo.messages : [];
  useEffect(() => { if (ref.current) ref.current.scrollTop = ref.current.scrollHeight; }, [msgs, loading]);

  const saveConvos = (u) => { setConvos(u); LS.set("at_coach_convos", u); };

  const newConvo = () => {
    const id = "c_" + Date.now();
    const c = { id, title: "Nouvelle conversation", messages: [], date: new Date().toISOString().slice(0,10) };
    const u = [c, ...convos]; saveConvos(u); setActiveId(id); setShowHistory(false);
  };

  const deleteConvo = (id) => {
    const u = convos.filter(c => c.id !== id); saveConvos(u);
    if (activeId === id) setActiveId(u.length ? u[0].id : null);
  };

  const updateMsgs = (newMsgs, title) => {
    const u = convos.map(c => c.id === activeId ? { ...c, messages: newMsgs, title: title || c.title } : c);
    saveConvos(u);
  };

  const saveKey = () => { if (!keyInput.trim()) return; localStorage.setItem("at_api_key", keyInput.trim()); setApiKey(keyInput.trim()); setKeyInput(""); if (!convos.length) newConvo(); };
  const clearKey = () => { localStorage.removeItem("at_api_key"); setApiKey(""); };
  const savePrompt = () => { LS.set("at_coach_prompt", promptText); setShowSettings(false); };
  const resetPrompt = () => setPromptText(DEFAULT_COACH_PROMPT);

  const send = async () => {
    if (!input.trim() || loading || !activeId) return;
    const txt = input.trim(); setInput(""); setError("");
    const newMsgs = [...msgs, { role:"user", text:txt }];
    const title = msgs.length === 0 ? txt.slice(0,50)+(txt.length>50?"...":"") : undefined;
    updateMsgs(newMsgs, title);
    setLoading(true);
    try {
      const rawReply = await callClaude(newMsgs, apiKey, pool);
      let reply = rawReply;
      const journalMatch = rawReply.match(/:::JOURNAL_ENTRY:::\s*(\{[\s\S]*?\})\s*:::END_JOURNAL:::/);
      if (journalMatch) {
        reply = rawReply.replace(/:::JOURNAL_ENTRY:::[\s\S]*?:::END_JOURNAL:::/, "").trim();
        try {
          const entry = JSON.parse(journalMatch[1]);
          const jEntry = { date: new Date().toISOString().slice(0,10), routine: entry.routine||"Séance", type: entry.type||"Hybride", duration: entry.duration||"", blocks: entry.blocks||[], notes: entry.notes||"" };
          const jrnl = LS.get("at_journal", []); jrnl.unshift(jEntry); LS.set("at_journal", jrnl);
          reply += "\n\n✅ Séance sauvegardée dans ton Journal!";
        } catch(pe) {}
      }
      const finalMsgs = [...newMsgs, { role:"assistant", text:reply }];
      updateMsgs(finalMsgs, title);
    } catch(e) {
      setError(e.message);
      if (e.message.includes("invalide")) { localStorage.removeItem("at_api_key"); setApiKey(""); }
    }
    setLoading(false);
  };

  // ── Écran saisie clé API ──
  if (!apiKey) return (
    <div style={{ maxWidth:480, margin:"0 auto", padding:"40px 0" }}>
      <div style={{ textAlign:"center", marginBottom:24 }}>
        <div style={{ fontSize:32, marginBottom:8 }}>🧠</div>
        <div style={{ fontSize:18, fontWeight:700, color:"#e8e4e1", marginBottom:6 }}>Coach IA</div>
        <div style={{ fontSize:13, color:"#888", lineHeight:1.6 }}>Pour activer ton coach, tu as besoin d'une clé API Anthropic.</div>
      </div>
      <div style={{ background:"#1c1a19", borderRadius:10, padding:"16px", marginBottom:16 }}>
        <div style={{ fontSize:12, fontWeight:600, color:"#ccc", marginBottom:8 }}>Comment obtenir ta clé:</div>
        <div style={{ fontSize:12, color:"#888", lineHeight:1.7, whiteSpace:"pre-line" }}>
          {"1. Va sur console.anthropic.com\n2. Crée un compte (si pas déjà fait)\n3. Va dans API Keys\n4. Crée une nouvelle clé\n5. Copie-la et colle-la ici"}
        </div>
      </div>
      <div style={{ display:"flex", gap:8 }}>
        <input type="password" value={keyInput} onChange={e => setKeyInput(e.target.value)} onKeyDown={e => e.key==="Enter" && saveKey()} placeholder="sk-ant-..."
          style={{ flex:1, background:"#222", border:"1px solid #333", borderRadius:8, padding:"12px 14px", fontSize:13, color:"#e8e4e1", outline:"none" }}
        />
        <button onClick={saveKey} style={{ background:keyInput.trim()?"#e8e4e1":"#333", color:keyInput.trim()?"#131211":"#555", border:"none", borderRadius:8, padding:"12px 20px", fontWeight:700, fontSize:13, cursor:keyInput.trim()?"pointer":"default" }}>
          Activer
        </button>
      </div>
      <div style={{ fontSize:10, color:"#555", marginTop:10, textAlign:"center" }}>Ta clé reste dans ton navigateur, jamais partagée.</div>
    </div>
  );

  // ── Réglages ──
  if (showSettings) return (
    <div className="fade-in">
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
        <div style={{ fontSize:15, fontWeight:700 }}>Réglages du Coach</div>
        <button onClick={() => setShowSettings(false)} style={{ background:"none", border:"none", fontSize:18, color:"#666", cursor:"pointer" }}>×</button>
      </div>
      <div style={{ fontSize:11, fontWeight:600, color:"#888", marginBottom:6, textTransform:"uppercase", letterSpacing:0.5 }}>Instructions personnalisées</div>
      <div style={{ fontSize:11, color:"#555", marginBottom:10, lineHeight:1.5 }}>Modifie ces instructions pour changer le comportement du coach.</div>
      <textarea value={promptText} onChange={e => setPromptText(e.target.value)}
        style={{ width:"100%", minHeight:280, background:"#1c1a19", border:"1px solid #2a2725", borderRadius:8, padding:"12px", fontSize:12, color:"#ccc", outline:"none", lineHeight:1.6, resize:"vertical" }}
      />
      <div style={{ display:"flex", gap:8, marginTop:12 }}>
        <button onClick={resetPrompt} style={{ padding:"9px 14px", borderRadius:8, border:"1px solid #333", background:"transparent", color:"#888", fontSize:12, fontWeight:500, cursor:"pointer" }}>Réinitialiser</button>
        <button onClick={clearKey} style={{ padding:"9px 14px", borderRadius:8, border:"1px solid #C4686833", background:"transparent", color:"#C46868", fontSize:12, fontWeight:500, cursor:"pointer" }}>Changer la clé API</button>
        <div style={{ flex:1 }} />
        <button onClick={savePrompt} style={{ padding:"9px 20px", borderRadius:8, border:"none", background:"#e8e4e1", color:"#131211", fontSize:12, fontWeight:700, cursor:"pointer" }}>Sauvegarder</button>
      </div>
    </div>
  );

  // ── Grouper conversations par date ──
  const groupedConvos = useMemo(() => {
    const groups = {}; const today = new Date().toISOString().slice(0,10); const yesterday = new Date(Date.now()-86400000).toISOString().slice(0,10);
    convos.forEach(c => {
      let label;
      if (c.date === today) label = "Aujourd'hui";
      else if (c.date === yesterday) label = "Hier";
      else { const [y,m,d] = c.date.split("-"); const mn = ["Jan","Fév","Mar","Avr","Mai","Jun","Jul","Aoû","Sep","Oct","Nov","Déc"]; label = d+" "+mn[parseInt(m)-1]+" "+y; }
      if (!groups[label]) groups[label] = [];
      groups[label].push(c);
    });
    return Object.entries(groups);
  }, [convos]);

  return (
    <div style={{ display:"flex", flexDirection:"column", minHeight:500 }}>
      {/* Top bar */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10, paddingBottom:8, borderBottom:"1px solid #2a2725" }}>
        <div ref={dropRef} style={{ display:"flex", alignItems:"center", gap:6, flex:1, minWidth:0, position:"relative" }}>
          <div style={{ width:6, height:6, borderRadius:3, background:"#7BB490", flexShrink:0 }} />
          <div onClick={() => setShowHistory(!showHistory)} style={{ display:"flex", alignItems:"center", gap:4, cursor:"pointer", minWidth:0 }}>
            <span style={{ fontSize:11, color:"#ccc", overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap", maxWidth:200, fontWeight:500 }}>
              {activeConvo ? activeConvo.title : "Coach IA"}
            </span>
            <span style={{ fontSize:8, color:"#555", transition:"transform 0.2s", transform:showHistory?"rotate(180deg)":"rotate(0)" }}>▼</span>
          </div>
          {/* Dropdown conversations */}
          {showHistory && (
            <div style={{ position:"absolute", top:"100%", left:0, marginTop:8, background:"#1c1a19", border:"1px solid #2a2725", borderRadius:10, width:300, maxHeight:400, overflowY:"auto", zIndex:50, boxShadow:"0 12px 40px rgba(0,0,0,0.5)" }}>
              <div style={{ padding:"10px 12px", borderBottom:"1px solid #2a2725", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
                <span style={{ fontSize:11, fontWeight:600, color:"#888" }}>{convos.length} conversation{convos.length>1?"s":""}</span>
                <button onClick={e => { e.stopPropagation(); newConvo(); }} style={{ background:"#e8e4e1", color:"#131211", border:"none", borderRadius:6, padding:"4px 12px", fontSize:10, fontWeight:700, cursor:"pointer" }}>+ Nouvelle</button>
              </div>
              {!convos.length && <div style={{ padding:"16px", textAlign:"center", color:"#555", fontSize:11 }}>Aucune conversation</div>}
              {groupedConvos.map(([dateLabel, items]) => (
                <div key={dateLabel}>
                  <div style={{ padding:"8px 12px 4px", fontSize:9, fontWeight:600, color:"#555", letterSpacing:0.8, textTransform:"uppercase" }}>{dateLabel}</div>
                  {items.map(c => (
                    <div key={c.id} onClick={() => { setActiveId(c.id); setShowHistory(false); }}
                      style={{ display:"flex", alignItems:"center", gap:8, padding:"8px 12px", cursor:"pointer", background:c.id===activeId?"#2a2725":"transparent", transition:"background 0.1s" }}
                    >
                      <div style={{ flex:1, minWidth:0 }}>
                        <div style={{ fontSize:11, fontWeight:500, color:c.id===activeId?"#e8e4e1":"#aaa", overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{c.title}</div>
                        <div style={{ fontSize:9, color:"#555", marginTop:1 }}>{c.messages.length} msg</div>
                      </div>
                      <button onClick={e => { e.stopPropagation(); deleteConvo(c.id); }} style={{ background:"none", border:"none", color:"#333", fontSize:12, cursor:"pointer", padding:"2px 4px", flexShrink:0 }}>×</button>
                    </div>
                  ))}
                </div>
              ))}
            </div>
          )}
        </div>
        <div style={{ display:"flex", gap:6, flexShrink:0 }}>
          <button onClick={newConvo} style={{ background:"none", border:"1px solid #333", borderRadius:6, padding:"4px 10px", fontSize:10, color:"#666", cursor:"pointer" }}>+ Nouvelle</button>
          <button onClick={() => setShowSettings(true)} style={{ background:"none", border:"1px solid #333", borderRadius:6, padding:"4px 10px", fontSize:10, color:"#666", cursor:"pointer" }}>⚙</button>
        </div>
      </div>

      {/* Messages */}
      <div ref={ref} style={{ flex:1, overflowY:"auto", display:"flex", flexDirection:"column", gap:10, paddingBottom:12 }}>
        {!activeId && <div style={{ textAlign:"center", padding:"40px", color:"#555" }}>Clique sur "+ Nouvelle" pour commencer.</div>}
        {activeId && !msgs.length && (
          <div style={{ textAlign:"center", padding:"30px 20px" }}>
            <div style={{ fontSize:28, marginBottom:8 }}>💬</div>
            <div style={{ fontSize:13, color:"#888", lineHeight:1.7, whiteSpace:"pre-line" }}>{"Pose-moi n'importe quelle question!\n\n• \"Fais-moi un workout de jambes\"\n• \"Comment améliorer mon Hyrox?\"\n• \"Quoi manger avant un training?\"\n• \"Plan de 4 semaines pour mes pull-ups\"\n• \"Analyse mes progressions\""}</div>
          </div>
        )}
        {msgs.map((m, i) => (
          <div key={i} className="fade-in" style={{ display:"flex", justifyContent:m.role==="user"?"flex-end":"flex-start" }}>
            <div style={{
              maxWidth:"88%", background:m.role==="user"?"#e8e4e1":"#1c1a19", color:m.role==="user"?"#131211":"#ccc",
              border:m.role==="user"?"none":"1px solid #2a2725",
              borderRadius:m.role==="user"?"12px 12px 2px 12px":"12px 12px 12px 2px",
              padding:"10px 14px", fontSize:13, lineHeight:1.65, whiteSpace:"pre-wrap"
            }}>{m.text}</div>
          </div>
        ))}
        {loading && <div className="typing" style={{ background:"#1c1a19", border:"1px solid #2a2725", borderRadius:"12px 12px 12px 2px", padding:"10px 14px", fontSize:13, color:"#555", width:"fit-content" }}>Réflexion en cours...</div>}
        {error && <div style={{ background:"#C4686815", border:"1px solid #C4686833", borderRadius:8, padding:"8px 12px", fontSize:12, color:"#C46868" }}>{error}</div>}
      </div>

      {/* Input */}
      {activeId && (
        <div style={{ display:"flex", gap:8, paddingTop:12, borderTop:"1px solid #2a2725", marginTop:8, flexShrink:0 }}>
          <input type="text" value={input} onChange={e => setInput(e.target.value)} onKeyDown={e => e.key==="Enter" && !e.shiftKey && send()} placeholder="Écris ton message..." disabled={loading}
            style={{ flex:1, background:"#1c1a19", border:"1px solid #333", borderRadius:8, padding:"11px 14px", fontSize:13, color:"#e8e4e1", outline:"none", opacity:loading?0.5:1 }}
          />
          <button onClick={send} disabled={loading}
            style={{ background:input.trim()&&!loading?"#e8e4e1":"#333", color:input.trim()&&!loading?"#131211":"#555", border:"none", borderRadius:8, padding:"11px 18px", fontWeight:700, fontSize:13, cursor:input.trim()&&!loading?"pointer":"default", transition:"all 0.2s", flexShrink:0 }}
          >{loading ? "..." : "Envoyer"}</button>
        </div>
      )}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 14 — JOURNAL — ENTRÉE
// ══════════════════════════════════════════════════════════════
function JournalEntry({ entry, index, onUpdate, onDelete, onStart }) {
  const [open, setOpen]       = useState(false);
  const [editing, setEditing] = useState(false);
  const [form, setForm]       = useState(entry);
  const [blockText, setBlockText] = useState((entry.blocks||[]).join("\n"));
  const tc = rtColors[entry.type] || "#888";
  const blocks = entry.blocks?.length ? entry.blocks : (entry.notes ? entry.notes.split("\n").filter(l => l.trim()) : []);
  const s = { width:"100%", background:"#222", border:"1px solid #333", borderRadius:6, padding:"8px 10px", fontSize:12, color:"#e8e4e1", outline:"none", marginBottom:6 };
  const l = { fontSize:9, fontWeight:600, color:"#666", marginBottom:2, display:"block", letterSpacing:0.5, textTransform:"uppercase" };

  const save = () => { const nb = blockText.split("\n").filter(l => l.trim()); onUpdate(index, { ...form, blocks:nb }); setEditing(false); };
  const cancel = () => { setForm(entry); setBlockText((entry.blocks||[]).join("\n")); setEditing(false); };

  if (editing) return (
    <div className="fade-in" style={{ background:"#1c1a19", border:"1px solid "+tc+"44", borderRadius:10, padding:"16px", marginBottom:6 }}>
      <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr 1fr", gap:6, marginBottom:4 }}>
        <div><label style={l}>Date</label><input type="date" style={s} value={form.date||""} onChange={e => setForm(p => ({ ...p, date:e.target.value }))} /></div>
        <div><label style={l}>Type</label>
          <select style={{ ...s, cursor:"pointer" }} value={form.type||"Hybride"} onChange={e => setForm(p => ({ ...p, type:e.target.value }))}>
            {ROUTINE_TYPES.filter(t => t!=="Tous").map(t => <option key={t} value={t}>{t}</option>)}
          </select>
        </div>
        <div><label style={l}>Durée</label><input style={s} value={form.duration||""} placeholder="55 min" onChange={e => setForm(p => ({ ...p, duration:e.target.value }))} /></div>
      </div>
      <label style={l}>Nom</label>
      <input style={s} value={form.routine||""} onChange={e => setForm(p => ({ ...p, routine:e.target.value }))} />
      <label style={l}>Blocs (1 par ligne)</label>
      <textarea style={{ ...s, minHeight:100, resize:"vertical", lineHeight:1.6 }} value={blockText} placeholder="Bloc 1: Back Squat 4×10\nBloc 2: RDL 4×8" onChange={e => setBlockText(e.target.value)} />
      <label style={l}>Notes</label>
      <textarea style={{ ...s, minHeight:40, resize:"vertical" }} value={form.notes||""} onChange={e => setForm(p => ({ ...p, notes:e.target.value }))} />
      <div style={{ display:"flex", gap:6, marginTop:4 }}>
        <button onClick={cancel} style={{ flex:1, padding:"8px", borderRadius:6, border:"1px solid #333", background:"transparent", color:"#888", fontSize:12, fontWeight:500, cursor:"pointer" }}>Annuler</button>
        <button onClick={save} style={{ flex:1, padding:"8px", borderRadius:6, border:"none", background:"#e8e4e1", color:"#131211", fontSize:12, fontWeight:700, cursor:"pointer" }}>Sauvegarder</button>
      </div>
    </div>
  );

  return (
    <div onClick={() => setOpen(!open)}
      style={{ background:"#1c1a19", border:"1px solid "+(open?tc+"44":"#2a2725"), borderRadius:10, padding:"14px 16px", cursor:"pointer", transition:"all 0.15s", marginBottom:6 }}
    >
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start" }}>
        <div style={{ flex:1 }}>
          <div style={{ fontWeight:600, fontSize:13, color:"#e8e4e1", marginBottom:4 }}>{entry.routine}</div>
          <div style={{ display:"flex", gap:4, alignItems:"center", flexWrap:"wrap" }}>
            <Badge color={tc}>{entry.type}</Badge>
            {entry.duration && <Badge color="#888">{entry.duration}</Badge>}
            <Badge color="#555">{entry.date}</Badge>
          </div>
        </div>
        <div style={{ display:"flex", gap:4, alignItems:"center", flexShrink:0 }}>
          <span style={{ fontSize:10, color:"#555" }}>{open?"Fermer":blocks.length+" bloc"+(blocks.length>1?"s":"")}</span>
          <button onClick={e => { e.stopPropagation(); setEditing(true); }} style={{ background:"none", border:"none", color:"#555", fontSize:11, cursor:"pointer", padding:"2px 6px" }}>✎</button>
          <button onClick={e => { e.stopPropagation(); onDelete(index); }} style={{ background:"none", border:"none", color:"#444", fontSize:14, cursor:"pointer", padding:"2px 6px" }}>×</button>
        </div>
      </div>
      {entry.notes && <div style={{ fontSize:11, color:"#777", marginTop:5, lineHeight:1.5 }}>{entry.notes}</div>}
      {open && (
        <div style={{ marginTop:10, paddingTop:10, borderTop:"1px solid #2a2725" }}>
          {blocks.map((b, i) => (
            <div key={i} style={{ display:"flex", gap:8, marginBottom:5 }}>
              <span style={{ background:tc+"20", color:tc, fontWeight:600, fontSize:9, width:18, height:18, borderRadius:4, display:"flex", alignItems:"center", justifyContent:"center", flexShrink:0, marginTop:1 }}>{i+1}</span>
              <span style={{ fontSize:12, color:"#aaa", lineHeight:1.5 }}>{b}</span>
            </div>
          ))}
          {!blocks.length && <div style={{ fontSize:12, color:"#555", fontStyle:"italic" }}>Aucun bloc détaillé.</div>}
          {blocks.length > 0 && (
            <button onClick={e => { e.stopPropagation(); onStart({ name:entry.routine, type:entry.type, duration:entry.duration, difficulty:3, blocks }); }}
              style={{ marginTop:10, width:"100%", padding:"10px", borderRadius:8, border:"none", background:tc, color:"#fff", fontWeight:700, fontSize:13, cursor:"pointer", letterSpacing:0.3 }}
            >▶  Commencer la séance</button>
          )}
        </div>
      )}
    </div>
  );
}

