// SECTION 15 — JOURNAL TAB
// ══════════════════════════════════════════════════════════════
function JournalTab({ onStart }) {
  const loadEntries = () => {
    const custom = LS.get("at_journal", []);
    const customDates = new Set(custom.map(e => e.date+"|"+e.routine));
    const base = BASE_JOURNAL.filter(e => !customDates.has(e.date+"|"+e.routine));
    return [...custom, ...base].sort((a, b) => b.date.localeCompare(a.date));
  };
  const [entries, setEntries]   = useState(loadEntries);
  const [showAdd, setShowAdd]   = useState(false);
  const [view, setView]         = useState("calendar");
  const [calMonth, setCalMonth] = useState(() => { const n = new Date(); return { y:n.getFullYear(), m:n.getMonth() }; });
  const [selectedDate, setSelectedDate] = useState(null);
  const [form, setForm] = useState({ date:new Date().toISOString().slice(0,10), routine:"", type:"Hybride", duration:"", blocks:[], notes:"" });

  useEffect(() => { setEntries(loadEntries()); }, []);

  const persist = (u) => { setEntries(u); LS.set("at_journal", u); };
  const save = () => { if (!form.routine.trim()) return; persist([{ ...form }, ...entries]); setForm({ date:new Date().toISOString().slice(0,10), routine:"", type:"Hybride", duration:"", blocks:[], notes:"" }); setShowAdd(false); };
  const del = (i) => persist(entries.filter((_, j) => j!==i));
  const update = (i, data) => { const u = [...entries]; u[i] = data; persist(u); };

  const s = { width:"100%", background:"#222", border:"1px solid #333", borderRadius:8, padding:"10px 12px", fontSize:13, color:"#e8e4e1", outline:"none", marginBottom:10 };
  const l = { fontSize:10, fontWeight:600, color:"#888", marginBottom:3, display:"block", letterSpacing:0.5, textTransform:"uppercase" };

  const grouped = {};
  entries.forEach((e, i) => { const m = e.date?.slice(0,7)||"autre"; if (!grouped[m]) grouped[m]=[]; grouped[m].push({ entry:e, index:i }); });
  const monthNames = {"01":"Janvier","02":"Février","03":"Mars","04":"Avril","05":"Mai","06":"Juin","07":"Juillet","08":"Août","09":"Septembre","10":"Octobre","11":"Novembre","12":"Décembre"};
  const monthFull = ["Janvier","Février","Mars","Avril","Mai","Juin","Juillet","Août","Septembre","Octobre","Novembre","Décembre"];
  const dayLabels = ["Dim","Lun","Mar","Mer","Jeu","Ven","Sam"];

  const calEntries = useMemo(() => {
    const map = {};
    entries.forEach(e => { if (e.date) { if (!map[e.date]) map[e.date]=[]; map[e.date].push(e); } });
    return map;
  }, [entries]);

  const calDays = useMemo(() => {
    const first = new Date(calMonth.y, calMonth.m, 1);
    const startDay = first.getDay();
    const daysInMonth = new Date(calMonth.y, calMonth.m+1, 0).getDate();
    const days = [];
    for (let i=0; i<startDay; i++) days.push(null);
    for (let d=1; d<=daysInMonth; d++) days.push(d);
    return days;
  }, [calMonth]);

  const todayStr = new Date().toISOString().slice(0,10);
  const dateStr = (d) => calMonth.y+"-"+String(calMonth.m+1).padStart(2,"0")+"-"+String(d).padStart(2,"0");
  const selectedEntries = selectedDate ? entries.map((e,i) => ({ entry:e, index:i })).filter(({entry}) => entry.date===selectedDate) : [];
  const prevMonth = () => setCalMonth(p => p.m===0 ? { y:p.y-1, m:11 } : { y:p.y, m:p.m-1 });
  const nextMonth = () => setCalMonth(p => p.m===11 ? { y:p.y+1, m:0 } : { y:p.y, m:p.m+1 });

  return (
    <div>
      {/* Header */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
        <div style={{ display:"flex", alignItems:"center", gap:8 }}>
          <div style={{ fontSize:12, fontWeight:600, color:"#e8e4e1" }}>{entries.length} séances</div>
          <div style={{ display:"flex", background:"#222", borderRadius:6, padding:2 }}>
            <button onClick={() => setView("calendar")} style={{ background:view==="calendar"?"#333":"transparent", color:view==="calendar"?"#e8e4e1":"#555", border:"none", borderRadius:4, padding:"4px 10px", fontSize:10, fontWeight:500, cursor:"pointer" }}>Calendrier</button>
            <button onClick={() => setView("list")} style={{ background:view==="list"?"#333":"transparent", color:view==="list"?"#e8e4e1":"#555", border:"none", borderRadius:4, padding:"4px 10px", fontSize:10, fontWeight:500, cursor:"pointer" }}>Liste</button>
          </div>
        </div>
        <button onClick={() => setShowAdd(!showAdd)} style={{ background:showAdd?"#333":"#e8e4e1", color:showAdd?"#888":"#131211", border:"none", borderRadius:8, padding:"8px 16px", fontSize:12, fontWeight:600, cursor:"pointer" }}>
          {showAdd ? "Annuler" : "+ Ajouter"}
        </button>
      </div>

      {/* Formulaire ajout */}
      {showAdd && (
        <div className="fade-in" style={{ background:"#1c1a19", border:"1px solid #2a2725", borderRadius:10, padding:"16px", marginBottom:16 }}>
          <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:8 }}>
            <div><label style={l}>Date</label><input type="date" style={s} value={form.date} onChange={e => setForm(p => ({ ...p, date:e.target.value }))} /></div>
            <div><label style={l}>Type</label>
              <select style={{ ...s, cursor:"pointer" }} value={form.type} onChange={e => setForm(p => ({ ...p, type:e.target.value }))}>
                {ROUTINE_TYPES.filter(t => t!=="Tous").map(t => <option key={t} value={t}>{t}</option>)}
              </select>
            </div>
          </div>
          <label style={l}>Nom *</label>
          <input style={s} placeholder="Ex: Leg Day Glute + StairMaster" value={form.routine} onChange={e => setForm(p => ({ ...p, routine:e.target.value }))} />
          <label style={l}>Durée</label>
          <input style={s} placeholder="Ex: 55 min" value={form.duration} onChange={e => setForm(p => ({ ...p, duration:e.target.value }))} />
          <label style={l}>Notes</label>
          <textarea style={{ ...s, minHeight:50, resize:"vertical" }} placeholder="PRs, sensations..." value={form.notes} onChange={e => setForm(p => ({ ...p, notes:e.target.value }))} />
          <button onClick={save} style={{ width:"100%", padding:"10px", borderRadius:8, border:"none", background:form.routine.trim()?"#e8e4e1":"#333", color:form.routine.trim()?"#131211":"#555", fontWeight:700, fontSize:13, cursor:form.routine.trim()?"pointer":"default" }}>Sauvegarder</button>
        </div>
      )}

      {/* Vue Calendrier */}
      {view === "calendar" && (
        <div>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:12 }}>
            <button onClick={prevMonth} style={{ background:"none", border:"1px solid #2a2725", borderRadius:6, padding:"6px 12px", color:"#888", fontSize:14, cursor:"pointer" }}>←</button>
            <div style={{ fontSize:14, fontWeight:700, color:"#e8e4e1" }}>{monthFull[calMonth.m]} {calMonth.y}</div>
            <button onClick={nextMonth} style={{ background:"none", border:"1px solid #2a2725", borderRadius:6, padding:"6px 12px", color:"#888", fontSize:14, cursor:"pointer" }}>→</button>
          </div>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(7, 1fr)", gap:2, marginBottom:4 }}>
            {dayLabels.map(d => <div key={d} style={{ textAlign:"center", fontSize:9, fontWeight:600, color:"#555", padding:"4px 0", textTransform:"uppercase", letterSpacing:0.5 }}>{d}</div>)}
          </div>
          <div style={{ display:"grid", gridTemplateColumns:"repeat(7, 1fr)", gap:2, marginBottom:16 }}>
            {calDays.map((d, i) => {
              if (d === null) return <div key={"e"+i} />;
              const ds = dateStr(d);
              const dayEntries = calEntries[ds] || [];
              const has = dayEntries.length > 0;
              const isToday = ds === todayStr;
              const isSelected = ds === selectedDate;
              const tc = has ? (rtColors[dayEntries[0].type] || "#888") : "#333";
              return (
                <div key={d} onClick={() => setSelectedDate(isSelected ? null : ds)}
                  style={{ position:"relative", aspectRatio:"1", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center", borderRadius:8, cursor:"pointer", transition:"all 0.15s",
                    background: isSelected ? tc+"25" : has ? "#1c1a19" : "transparent",
                    border: isSelected ? "1px solid "+tc+"66" : isToday ? "1px solid #444" : "1px solid transparent"
                  }}
                >
                  <span style={{ fontSize:12, fontWeight:isToday?700:has?600:400, color:isToday?"#e8e4e1":has?"#ccc":"#444" }}>{d}</span>
                  {has && <div style={{ display:"flex", gap:2, marginTop:2 }}>
                    {dayEntries.slice(0,3).map((e,j) => <div key={j} style={{ width:5, height:5, borderRadius:3, background:rtColors[e.type]||"#888" }} />)}
                  </div>}
                  {dayEntries.length > 1 && <span style={{ fontSize:7, color:"#888", marginTop:1 }}>{dayEntries.length}x</span>}
                </div>
              );
            })}
          </div>
          {selectedDate && (
            <div className="fade-in">
              <div style={{ fontSize:11, fontWeight:600, color:"#888", marginBottom:8, paddingBottom:6, borderBottom:"1px solid #2a2725" }}>
                {selectedDate} — {selectedEntries.length} séance{selectedEntries.length>1?"s":""}
              </div>
              {selectedEntries.map(({ entry, index }) => <JournalEntry key={index} entry={entry} index={index} onUpdate={update} onDelete={del} onStart={onStart} />)}
              {!selectedEntries.length && <div style={{ textAlign:"center", padding:"16px", color:"#555", fontSize:12 }}>Aucune séance ce jour.</div>}
            </div>
          )}
        </div>
      )}

      {/* Vue Liste */}
      {view === "list" && (
        <div>
          <div style={{ fontSize:10, color:"#555", marginBottom:14, fontStyle:"italic" }}>Astuce: dis au Coach IA "aujourd'hui je fais..." et il sauvegarde ta séance ici automatiquement.</div>
          {Object.entries(grouped).map(([month, items]) => {
            const [y, m] = month.split("-");
            const label = (monthNames[m]||m)+" "+y;
            return (
              <div key={month} style={{ marginBottom:20 }}>
                <div style={{ fontSize:11, fontWeight:600, color:"#555", letterSpacing:1, textTransform:"uppercase", marginBottom:8, paddingBottom:6, borderBottom:"1px solid #2a2725" }}>
                  {label} — {items.length} séance{items.length>1?"s":""}
                </div>
                {items.map(({ entry, index }) => <JournalEntry key={index} entry={entry} index={index} onUpdate={update} onDelete={del} onStart={onStart} />)}
              </div>
            );
          })}
          {!entries.length && <div style={{ textAlign:"center", padding:"40px 20px", color:"#555" }}><div style={{ fontSize:28, marginBottom:8 }}>📝</div><div style={{ fontSize:13 }}>Aucune séance enregistrée.</div></div>}
        </div>
      )}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 16 — PLANIFICATEUR DE SEMAINE
// ══════════════════════════════════════════════════════════════
function WeekTab({ onStart }) {
  const [weekOffset, setWeekOffset] = useState(0);
  const [plan, setPlan]             = useState(() => LS.get("at_week_plan", {}));
  const [assigning, setAssigning]   = useState(null);

  const weekStart = useMemo(() => { const d = new Date(); d.setDate(d.getDate() - d.getDay() + weekOffset*7); return d; }, [weekOffset]);

  const days = useMemo(() => {
    const labels = ["Dimanche","Lundi","Mardi","Mercredi","Jeudi","Vendredi","Samedi"];
    const shortMonth = ["jan","fév","mar","avr","mai","jun","jul","aoû","sep","oct","nov","déc"];
    return Array.from({ length:7 }, (_, i) => {
      const d = new Date(weekStart); d.setDate(weekStart.getDate()+i);
      const ds = d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");
      return { index:i, label:labels[i], date:ds, dayNum:d.getDate(), monthLabel:shortMonth[d.getMonth()], isToday:ds===new Date().toISOString().slice(0,10) };
    });
  }, [weekStart]);

  const savePlan = (u) => { setPlan(u); LS.set("at_week_plan", u); };
  const assign = (dateStr, routine) => { savePlan({ ...plan, [dateStr]:routine }); setAssigning(null); };
  const remove = (dateStr) => { const u = { ...plan }; delete u[dateStr]; savePlan(u); };

  const journal = useMemo(() => {
    const custom = LS.get("at_journal", []);
    const customDates = new Set(custom.map(e => e.date+"|"+e.routine));
    const base = BASE_JOURNAL.filter(e => !customDates.has(e.date+"|"+e.routine));
    return [...custom, ...base];
  }, []);

  const journalDates = useMemo(() => {
    const map = {};
    journal.forEach(e => { if (e.date) { if (!map[e.date]) map[e.date]=[]; map[e.date].push(e); } });
    return map;
  }, [journal]);

  const weekLabel = useMemo(() => {
    const end = new Date(weekStart); end.setDate(weekStart.getDate()+6);
    const sm = ["jan","fév","mar","avr","mai","jun","jul","aoû","sep","oct","nov","déc"];
    return weekStart.getDate()+" "+sm[weekStart.getMonth()]+" — "+end.getDate()+" "+sm[end.getMonth()]+" "+end.getFullYear();
  }, [weekStart]);

  return (
    <div>
      {/* Navigation semaine */}
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:16 }}>
        <button onClick={() => setWeekOffset(w => w-1)} style={{ background:"none", border:"1px solid #2a2725", borderRadius:6, padding:"6px 12px", color:"#888", fontSize:14, cursor:"pointer" }}>←</button>
        <div style={{ textAlign:"center" }}>
          <div style={{ fontSize:14, fontWeight:700, color:"#e8e4e1" }}>{weekLabel}</div>
          {weekOffset !== 0 && <button onClick={() => setWeekOffset(0)} style={{ background:"none", border:"none", color:"#C47A8A", fontSize:10, cursor:"pointer", marginTop:2 }}>Revenir à cette semaine</button>}
        </div>
        <button onClick={() => setWeekOffset(w => w+1)} style={{ background:"none", border:"1px solid #2a2725", borderRadius:6, padding:"6px 12px", color:"#888", fontSize:14, cursor:"pointer" }}>→</button>
      </div>

      {days.map(day => {
        const planned = plan[day.date];
        const done = journalDates[day.date] || [];
        const hasDone = done.length > 0;
        const tc = planned ? (rtColors[planned.type]||"#888") : "#333";

        return (
          <div key={day.date} style={{ background:"#1c1a19", border:day.isToday?"1px solid #444":"1px solid #2a2725", borderRadius:10, padding:"14px 16px", marginBottom:6 }}>
            <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:planned||hasDone?10:0 }}>
              <div style={{ display:"flex", alignItems:"center", gap:8 }}>
                <div style={{ width:36, height:36, borderRadius:8, background:day.isToday?"#C47A8A20":"#222", display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center" }}>
                  <span style={{ fontSize:14, fontWeight:700, color:day.isToday?"#C47A8A":"#888", lineHeight:1 }}>{day.dayNum}</span>
                  <span style={{ fontSize:7, color:day.isToday?"#C47A8A":"#555", textTransform:"uppercase", fontWeight:600 }}>{day.monthLabel}</span>
                </div>
                <div>
                  <div style={{ fontSize:12, fontWeight:600, color:day.isToday?"#e8e4e1":"#aaa" }}>{day.label}</div>
                  {hasDone && <div style={{ display:"flex", alignItems:"center", gap:4, marginTop:2 }}>
                    <div style={{ width:6, height:6, borderRadius:3, background:"#7BB490" }} />
                    <span style={{ fontSize:9, color:"#7BB490", fontWeight:500 }}>{done.length} séance{done.length>1?"s":""} complétée{done.length>1?"s":""}</span>
                  </div>}
                </div>
              </div>
              {!planned && <button onClick={() => setAssigning(assigning===day.date ? null : day.date)}
                style={{ background:assigning===day.date?"#333":"none", border:"1px solid #2a2725", borderRadius:6, padding:"4px 10px", fontSize:10, color:"#666", cursor:"pointer" }}
              >{assigning===day.date ? "Annuler" : "+ Planifier"}</button>}
            </div>

            {planned && (
              <div style={{ background:tc+"10", border:"1px solid "+tc+"33", borderRadius:8, padding:"10px 12px", display:"flex", justifyContent:"space-between", alignItems:"center" }}>
                <div>
                  <div style={{ fontSize:12, fontWeight:600, color:"#e8e4e1", marginBottom:3 }}>{planned.name}</div>
                  <div style={{ display:"flex", gap:4 }}>
                    <Badge color={tc}>{planned.type}</Badge>
                    <Badge color="#888">{planned.duration}</Badge>
                  </div>
                </div>
                <div style={{ display:"flex", gap:4 }}>
                  <button onClick={() => onStart(planned)} style={{ background:tc, color:"#fff", border:"none", borderRadius:6, padding:"6px 12px", fontSize:10, fontWeight:700, cursor:"pointer" }}>▶</button>
                  <button onClick={() => remove(day.date)} style={{ background:"none", border:"none", color:"#444", fontSize:14, cursor:"pointer", padding:"2px 6px" }}>×</button>
                </div>
              </div>
            )}

            {hasDone && done.map((e, j) => {
              const dc = rtColors[e.type] || "#888";
              return (
                <div key={j} style={{ display:"flex", alignItems:"center", gap:8, padding:"6px 0", borderTop:j===0&&planned?"1px solid #2a2725":"none", marginTop:j===0&&planned?8:0 }}>
                  <div style={{ width:4, height:20, borderRadius:2, background:dc, flexShrink:0 }} />
                  <div style={{ flex:1, minWidth:0 }}>
                    <div style={{ fontSize:11, fontWeight:500, color:"#aaa", overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{e.routine}</div>
                    <div style={{ fontSize:9, color:"#555" }}>{e.type}{e.duration?" · "+e.duration:""}</div>
                  </div>
                  <div style={{ fontSize:9, color:"#7BB490", fontWeight:600 }}>✓</div>
                </div>
              );
            })}

            {assigning === day.date && (
              <div className="fade-in" style={{ marginTop:10, paddingTop:10, borderTop:"1px solid #2a2725" }}>
                <div style={{ fontSize:10, fontWeight:600, color:"#666", marginBottom:8, textTransform:"uppercase", letterSpacing:0.5 }}>Choisir une routine</div>
                <div style={{ display:"grid", gridTemplateColumns:"1fr 1fr", gap:4, maxHeight:200, overflowY:"auto" }}>
                  {BASE_ROUTINES.map(r => {
                    const rc = rtColors[r.type] || "#888";
                    return (
                      <button key={r.id} onClick={() => assign(day.date, r)}
                        style={{ background:"#222", border:"1px solid #2a2725", borderRadius:6, padding:"8px 10px", cursor:"pointer", textAlign:"left" }}
                      >
                        <div style={{ fontSize:10, fontWeight:600, color:"#ccc", marginBottom:2, overflow:"hidden", textOverflow:"ellipsis", whiteSpace:"nowrap" }}>{r.name}</div>
                        <div style={{ display:"flex", gap:3 }}><Badge color={rc}>{r.type}</Badge><Badge color="#666">{r.duration}</Badge></div>
                      </button>
                    );
                  })}
                </div>
              </div>
            )}
          </div>
        );
      })}
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 17 — STATS
// ══════════════════════════════════════════════════════════════
function StatsTab({ exercises, maxF }) {
  const journal = useMemo(() => {
    const custom = LS.get("at_journal", []);
    const customDates = new Set(custom.map(e => e.date+"|"+e.routine));
    const base = BASE_JOURNAL.filter(e => !customDates.has(e.date+"|"+e.routine));
    return [...custom, ...base];
  }, []);

  const today = new Date();
  const todayStr = today.toISOString().slice(0,10);
  const toLocal = (s) => { const [y,m,d] = s.split("-").map(Number); return new Date(y, m-1, d); };
  const toStr = (d) => d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0");
  const getWeekKey = (d) => { const w = new Date(d); w.setDate(w.getDate()-w.getDay()); return toStr(w); };

  const journalStats = useMemo(() => {
    const now = new Date();
    const weekStr = getWeekKey(now);
    const monthStr = now.getFullYear()+"-"+String(now.getMonth()+1).padStart(2,"0")+"-01";
    let thisWeek=0, thisMonth=0, total=journal.length;
    const typeCounts = {}, weekCounts = {}, monthCounts = {};

    const uniqueDates = [...new Set(journal.map(e => e.date).filter(Boolean))].sort().reverse();
    let streak = 0;
    if (uniqueDates.length) {
      let check = new Date(now);
      if (!uniqueDates.includes(todayStr)) check.setDate(check.getDate()-1);
      for (let i=0; i<365; i++) {
        if (uniqueDates.includes(toStr(check))) { streak++; check.setDate(check.getDate()-1); } else break;
      }
    }

    journal.forEach(e => {
      if (!e.date) return;
      if (e.date >= weekStr) thisWeek++;
      if (e.date >= monthStr) thisMonth++;
      if (e.type) typeCounts[e.type] = (typeCounts[e.type]||0)+1;
      const d = toLocal(e.date);
      weekCounts[getWeekKey(d)] = (weekCounts[getWeekKey(d)]||0)+1;
      monthCounts[e.date.slice(0,7)] = (monthCounts[e.date.slice(0,7)]||0)+1;
    });

    const months = [];
    const monthShort = ["Jan","Fév","Mar","Avr","Mai","Jun","Jul","Aoû","Sep","Oct","Nov","Déc"];
    if (journal.length) {
      const sorted = [...journal].sort((a,b) => a.date.localeCompare(b.date));
      const first = toLocal(sorted[0].date);
      let cursor = new Date(first.getFullYear(), first.getMonth(), 1);
      const end = new Date(now.getFullYear(), now.getMonth(), 1);
      while (cursor <= end) {
        const mk = toStr(cursor).slice(0,7);
        months.push({ key:mk, label:monthShort[cursor.getMonth()]+" "+String(cursor.getFullYear()).slice(2), count:monthCounts[mk]||0 });
        cursor.setMonth(cursor.getMonth()+1);
      }
    }

    const activeWeeks = Object.keys(weekCounts).length;
    const avgPerWeek = activeWeeks > 0 ? (total/activeWeeks).toFixed(1) : "0";
    const typeArr = Object.entries(typeCounts).sort((a,b) => b[1]-a[1]);
    return { thisWeek, thisMonth, total, streak, typeArr, months, avgPerWeek };
  }, [journal]);

  const catStats = useMemo(() => {
    const cats = {};
    exercises.forEach(e => { cats[e.category] = (cats[e.category]||0)+e.frequency; });
    return Object.entries(cats).sort((a,b) => b[1]-a[1]);
  }, [exercises]);

  const maxMonth = Math.max(...journalStats.months.map(m => m.count), 1);

  return (
    <div>
      {/* Overview cards */}
      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(70px, 1fr))", gap:6, marginBottom:20 }}>
        {[
          { l:"Cette semaine", v:journalStats.thisWeek,   c:"#C47A8A" },
          { l:"Ce mois",       v:journalStats.thisMonth,  c:"#D49A64" },
          { l:"Total",         v:journalStats.total,      c:"#5BA3B5" },
          { l:"Streak",        v:journalStats.streak+"j", c:"#7BB490" },
          { l:"Moy/sem",       v:journalStats.avgPerWeek, c:"#A890B8" },
        ].map((s, i) => (
          <div key={i} style={{ background:"#1c1a19", borderRadius:8, padding:"12px 10px", textAlign:"center" }}>
            <div style={{ fontSize:22, fontWeight:800, color:s.c, lineHeight:1.2 }}>{s.v}</div>
            <div style={{ fontSize:9, color:"#666", marginTop:3, fontWeight:500, textTransform:"uppercase", letterSpacing:0.8 }}>{s.l}</div>
          </div>
        ))}
      </div>

      {/* Histogramme mensuel */}
      <div style={{ fontSize:12, fontWeight:600, marginBottom:10 }}>Séances par mois</div>
      <div style={{ background:"#1c1a19", borderRadius:8, padding:"16px 14px", marginBottom:20 }}>
        <div style={{ display:"flex", alignItems:"flex-end", gap:3, height:100 }}>
          {journalStats.months.map((m, i) => {
            const h = Math.max((m.count/maxMonth)*75, m.count>0?6:2);
            const isThisMonth = i === journalStats.months.length-1;
            return (
              <div key={m.key} style={{ flex:1, display:"flex", flexDirection:"column", alignItems:"center", gap:4 }}>
                <span style={{ fontSize:9, fontWeight:600, color:m.count>0?"#e8e4e1":"#555" }}>{m.count}</span>
                <div style={{ width:"100%", height:h, background:isThisMonth?"#C47A8A":m.count>0?"#C47A8A55":"#2a2725", borderRadius:3, transition:"height 0.3s" }} />
                <span style={{ fontSize:7, color:isThisMonth?"#C47A8A":"#555", fontWeight:isThisMonth?600:400 }}>{m.label}</span>
              </div>
            );
          })}
        </div>
      </div>

      {/* Répartition par type */}
      {journalStats.typeArr.length > 0 && (
        <div>
          <div style={{ fontSize:12, fontWeight:600, marginBottom:10 }}>Répartition par type</div>
          <div style={{ background:"#1c1a19", borderRadius:8, padding:"12px 14px", marginBottom:20 }}>
            {journalStats.typeArr.map(([type, count]) => {
              const c = rtColors[type] || "#888";
              const p = (count/journalStats.typeArr[0][1])*100;
              return (
                <div key={type} style={{ display:"flex", alignItems:"center", gap:8, marginBottom:5 }}>
                  <div style={{ width:85, fontSize:10, fontWeight:500, color:"#999" }}>{type}</div>
                  <div style={{ flex:1, height:14, background:"#2a2725", borderRadius:3, overflow:"hidden", position:"relative" }}>
                    <div style={{ width:p+"%", height:"100%", background:c+"33", borderRadius:3 }} />
                    <span style={{ position:"absolute", right:6, top:"50%", transform:"translateY(-50%)", fontSize:9, fontWeight:600, color:c }}>{count}</span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      {/* Volume par catégorie */}
      <div style={{ fontSize:12, fontWeight:600, marginBottom:10 }}>Volume par catégorie (banque)</div>
      <div style={{ background:"#1c1a19", borderRadius:8, padding:"12px 14px", marginBottom:20 }}>
        {catStats.map(([cat, total]) => {
          const c = catColors[cat] || "#888";
          const p = (total/catStats[0][1])*100;
          return (
            <div key={cat} style={{ display:"flex", alignItems:"center", gap:8, marginBottom:5 }}>
              <div style={{ width:85, fontSize:10, fontWeight:500, color:"#999" }}>{cat}</div>
              <div style={{ flex:1, height:14, background:"#2a2725", borderRadius:3, overflow:"hidden", position:"relative" }}>
                <div style={{ width:p+"%", height:"100%", background:c+"33", borderRadius:3 }} />
                <span style={{ position:"absolute", right:6, top:"50%", transform:"translateY(-50%)", fontSize:9, fontWeight:600, color:c }}>{total}</span>
              </div>
            </div>
          );
        })}
      </div>

      {/* Progressions */}
      <div style={{ fontSize:12, fontWeight:600, marginBottom:10 }}>Progressions</div>
      <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill, minmax(160px, 1fr))", gap:6 }}>
        {[
          { name:"Hip Abduction",      s:"70",  e:"185", p:"+164%" },
          { name:"Leg Press",          s:"150", e:"310", p:"+107%" },
          { name:"Hack Press",         s:"200", e:"360", p:"+80%"  },
          { name:"Leg Curl (tempo)",   s:"80",  e:"140", p:"+75%"  },
          { name:"Leg Curl (squeeze)", s:"70",  e:"110", p:"+57%"  },
          { name:"Hip Thrust",         s:"115", e:"175", p:"+52%"  },
          { name:"RDL",                s:"115", e:"145", p:"+26%"  },
          { name:"Back Squat",         s:"135", e:"155", p:"+15%"  },
        ].map((x, i) => (
          <div key={i} style={{ background:"#1c1a19", borderRadius:8, padding:"10px 12px" }}>
            <div style={{ fontSize:11, fontWeight:600, color:"#ccc", marginBottom:3 }}>{x.name}</div>
            <div style={{ fontSize:10, color:"#666" }}>{x.s} → <span style={{ color:"#7BB490", fontWeight:600 }}>{x.e} lb</span></div>
            <div style={{ fontSize:16, fontWeight:700, color:"#7BB490", marginTop:2 }}>{x.p}</div>
          </div>
        ))}
      </div>
    </div>
  );
}

// ══════════════════════════════════════════════════════════════
// SECTION 18 — APP PRINCIPALE
// ══════════════════════════════════════════════════════════════
function App() {
  const [tab, setTab]             = useState("exercises");
  const [search, setSearch]       = useState("");
  const [category, setCategory]   = useState("Tous");
  const [equipment, setEquipment] = useState("Tous");
  const [sortBy, setSortBy]       = useState("frequency");
  const [routineType, setRoutineType] = useState("Tous");
  const [showAdd, setShowAdd]     = useState(false);
  const [custom, setCustom]       = useState(() => LS.get("at_custom_ex", []));
  const [session, setSession]     = useState(null);

  const all = useMemo(() => [...BASE_EXERCISES, ...custom.map((e, i) => ({ ...e, id:"c"+i, frequency:e.frequency||1 }))], [custom]);
  const maxF = Math.max(...all.map(e => e.frequency));

  const filtered = useMemo(() => {
    let r = all.filter(e => {
      if (search && !e.name.toLowerCase().includes(search.toLowerCase()) && !(e.notes||"").toLowerCase().includes(search.toLowerCase())) return false;
      if (category !== "Tous" && e.category !== category) return false;
      if (equipment !== "Tous" && !(e.equipment||"").includes(equipment)) return false;
      return true;
    });
    if (sortBy === "frequency") r.sort((a,b) => b.frequency-a.frequency);
    else if (sortBy === "name") r.sort((a,b) => a.name.localeCompare(b.name));
    else if (sortBy === "category") r.sort((a,b) => a.category.localeCompare(b.category)||b.frequency-a.frequency);
    return r;
  }, [search, category, equipment, sortBy, all]);

  const filteredRt = useMemo(() => BASE_ROUTINES.filter(r => routineType==="Tous" || r.type===routineType), [routineType]);
  const addEx = (f) => { const u = [...custom, { ...f, frequency:1 }]; setCustom(u); LS.set("at_custom_ex", u); };

  const tabs = [
    { key:"exercises", label:"Exercices" },
    { key:"routines",  label:"Routines"  },
    { key:"week",      label:"Semaine"   },
    { key:"coach",     label:"Coach IA"  },
    { key:"journal",   label:"Journal"   },
    { key:"stats",     label:"Stats"     },
  ];

  const inp = { background:"#1c1a19", color:"#e8e4e1", border:"1px solid #2a2725", borderRadius:8, padding:"9px 12px", fontSize:12, outline:"none", cursor:"pointer", minWidth:85 };

  if (session) return <SessionMode routine={session} onEnd={() => setSession(null)} />;

  return (
    <div style={{ minHeight:"100vh", background:"#131211" }}>
      {showAdd && <AddModal onClose={() => setShowAdd(false)} onSave={addEx} />}

      {/* HEADER */}
      <div style={{ background:"#1c1a19", borderBottom:"1px solid #2a2725", padding:"28px 20px 22px" }}>
        <div style={{ maxWidth:900, margin:"0 auto" }}>
          <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", marginBottom:16 }}>
            <div>
              <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:3 }}>
                <div style={{ width:3, height:12, background:"#C47A8A", borderRadius:2 }} />
                <span style={{ fontSize:10, fontWeight:600, color:"#C47A8A", letterSpacing:2, textTransform:"uppercase" }}>training database</span>
              </div>
              <div style={{ fontSize:22, fontWeight:700, color:"#e8e4e1", letterSpacing:-0.5 }}>Alexanne's Training</div>
            </div>
            <button onClick={() => setShowAdd(true)} style={{ background:"#e8e4e1", color:"#131211", border:"none", borderRadius:8, padding:"8px 16px", fontSize:12, fontWeight:700, cursor:"pointer" }}>
              + Ajouter
            </button>
          </div>

          {/* Mini stats header */}
          <div style={{ display:"flex", gap:6, marginBottom:14 }}>
            {[
              { l:"Exercices", v:all.length,                                                                                    c:"#C47A8A" },
              { l:"Routines",  v:BASE_ROUTINES.length,                                                                          c:"#D49A64" },
              { l:"Séances",   v:(() => { const c=LS.get("at_journal",[]); const cd=new Set(c.map(e=>e.date+"|"+e.routine)); return c.length+BASE_JOURNAL.filter(e=>!cd.has(e.date+"|"+e.routine)).length; })(), c:"#5BA3B5" },
            ].map((s, i) => (
              <div key={i} style={{ background:"#222", borderRadius:6, padding:"7px 12px" }}>
                <div style={{ fontSize:16, fontWeight:700, color:s.c, lineHeight:1.2 }}>{s.v}</div>
                <div style={{ fontSize:9, color:"#666", marginTop:1, fontWeight:500, textTransform:"uppercase", letterSpacing:0.8 }}>{s.l}</div>
              </div>
            ))}
          </div>

          {/* Tabs */}
          <div style={{ display:"flex", gap:2, background:"#222", borderRadius:8, padding:3, width:"fit-content", overflowX:"auto" }}>
            {tabs.map(t => (
              <button key={t.key} onClick={() => setTab(t.key)}
                style={{ background:tab===t.key?"#333":"transparent", color:tab===t.key?"#e8e4e1":"#666", border:"none", borderRadius:6, padding:"7px 14px", fontSize:11, fontWeight:tab===t.key?600:500, cursor:"pointer", transition:"all 0.15s", whiteSpace:"nowrap", display:"flex", alignItems:"center", gap:4 }}
              >
                {t.label}
                {t.key==="coach" && <span style={{ fontSize:8, background:"#C47A8A", color:"#fff", padding:"1px 4px", borderRadius:3, fontWeight:700 }}>IA</span>}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* CONTENU */}
      <div style={{ maxWidth:900, margin:"0 auto", padding:"20px 20px 80px" }}>

        {/* Onglet Exercices */}
        {tab === "exercises" && (
          <div>
            <div style={{ display:"flex", gap:6, flexWrap:"wrap", marginBottom:14 }}>
              <input type="text" placeholder="Rechercher..." value={search} onChange={e => setSearch(e.target.value)} style={{ ...inp, flex:"1 1 160px", minWidth:160 }} />
              <select value={category} onChange={e => setCategory(e.target.value)} style={inp}>
                {CATEGORIES.map(c => <option key={c} value={c}>{c}</option>)}
              </select>
              <select value={equipment} onChange={e => setEquipment(e.target.value)} style={inp}>
                {EQUIPMENT_LIST.map(eq => <option key={eq} value={eq}>{eq==="Tous"?"Équipement":eq}</option>)}
              </select>
              <select value={sortBy} onChange={e => setSortBy(e.target.value)} style={inp}>
                <option value="frequency">Fréquence</option>
                <option value="name">A → Z</option>
                <option value="category">Catégorie</option>
              </select>
            </div>
            <div style={{ fontSize:11, color:"#555", marginBottom:10 }}>{filtered.length} exercice{filtered.length>1?"s":""}</div>
            {filtered.map(ex => <ExCard key={ex.id} ex={ex} maxF={maxF} />)}
          </div>
        )}

        {/* Onglet Routines */}
        {tab === "routines" && (
          <div>
            <div style={{ display:"flex", gap:4, flexWrap:"wrap", marginBottom:14 }}>
              {ROUTINE_TYPES.map(rt => (
                <button key={rt} onClick={() => setRoutineType(rt)}
                  style={{ background:routineType===rt?(rtColors[rt]||"#C47A8A")+"18":"transparent", color:routineType===rt?rtColors[rt]||"#C47A8A":"#666", border:"1px solid "+(routineType===rt?(rtColors[rt]||"#C47A8A")+"44":"#2a2725"), borderRadius:6, padding:"6px 12px", fontSize:11, fontWeight:500, cursor:"pointer" }}
                >{rt}</button>
              ))}
            </div>
            {filteredRt.map(r => <RtCard key={r.id} routine={r} onStart={setSession} />)}
          </div>
        )}

        {tab === "week"    && <WeekTab  onStart={setSession} />}
        {tab === "coach"   && <CoachTab pool={all} />}
        {tab === "journal" && <JournalTab onStart={setSession} />}
        {tab === "stats"   && <StatsTab exercises={all} maxF={maxF} />}
      </div>

      {/* FOOTER */}
      <div style={{ borderTop:"1px solid #2a2725", padding:"16px 20px", textAlign:"center", fontSize:9, color:"#444", letterSpacing:1, textTransform:"uppercase" }}>
        Alexanne's Training · Juin 2025 – Avril 2026
      </div>

      {/* TIMER DE REPOS FLOTTANT */}
      <RestTimer />
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
